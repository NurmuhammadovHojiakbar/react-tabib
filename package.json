{
  "name": "@boychibor/react-tabib",
  "version": "0.1.0",
  "description": "Static analysis CLI for finding likely memory leaks and lifecycle misuse in React apps.",
  "license": "MIT",
  "bin": {
    "react-tabib": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write ."
  },
  "keywords": [
    "react",
    "memory-leak",
    "static-analysis",
    "cli",
    "audit"
  ],
  "dependencies": {
    "@babel/parser": "^7.27.0",
    "@babel/traverse": "^7.27.0",
    "commander": "^14.0.0",
    "fast-glob": "^3.3.3",
    "picocolors": "^1.1.1",
    "typescript": "^5.8.2"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "@types/babel__traverse": "^7.20.7",
    "@types/node": "^22.13.10",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "vitest": "^3.0.9"
  }
}
